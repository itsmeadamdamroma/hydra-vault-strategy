        {"name": "vaultTokenAccount", "isMut": true, "isSigner": false},
        {"name": "shareMint", "isMut": true, "isSigner": false},
        {"name": "withdrawerTokenAccount", "isMut": true, "isSigner": false},
        {"name": "withdrawerShareAccount", "isMut": true, "isSigner": false},
