# Solana RPC (Helius recommended — free tier available for hackathon participants)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Keypair paths (admin and manager can be the same for solo operation)
ADMIN_KEYPAIR_PATH=/path/to/admin.json
MANAGER_KEYPAIR_PATH=/path/to/manager.json

# USDC Mint on Solana Mainnet
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Strategy Parameters
MAX_ALLOCATION_PER_PROTOCOL=40
MIN_IDLE_BUFFER_PCT=5
REBALANCE_THRESHOLD_APY=0.5
REBALANCE_INTERVAL_MS=60000
MAX_DRAWDOWN_PCT=3

# AI Engine
RISK_WEIGHT_TVL=0.3
RISK_WEIGHT_AUDIT=0.25
RISK_WEIGHT_AGE=0.2
RISK_WEIGHT_INCIDENTS=0.25
